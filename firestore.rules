rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - stats: map (required)
    //   - createdAt: timestamp (required)
    //   - lastLogin: timestamp (required)
    //   - role: string (optional, 'admin' or 'user')
    //
    // Collection: quizzes
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - questions: list (required)
    //   - creatorId: string (required)
    //   - createdAt: timestamp (required)
    //   - shareCount: number (required)
    //
    // Collection: history
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - quizId: string (required)
    //   - score: number (required)
    //   - totalQuestions: number (required)
    //   - timeTaken: number (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "danielgiobari644@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'stats', 'createdAt', 'lastLogin']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.email is string && data.email.matches('^.+@.+$') &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidQuiz(data) {
      return data.keys().hasAll(['title', 'description', 'questions', 'creatorId', 'createdAt']) &&
             data.title is string && data.title.size() < 200 &&
             data.questions is list && data.questions.size() <= 50 &&
             data.creatorId == request.auth.uid;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['userId', 'quizId', 'score', 'totalQuestions', 'timeTaken', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.score is number && data.score >= 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) || isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if true; // Quizzes are public for sharing
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shareCount']));
      allow delete: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidHistory(request.resource.data);
    }
  }
}
